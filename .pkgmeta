# BigWigsMods packager config (CurseForge / WoWInterface / GitHub releases).
# https://github.com/BigWigsMods/packager

package-as: HealerManaBars

# This addon bundles no embedded libraries (LibSharedMedia/ElvUI are optional
# and provided by the user's other addons), so the no-lib zip is unnecessary.
enable-nolib-creation: no

# Use the hand-written changelog rather than an auto-generated commit list.
# Declare markup-type so CurseForge/Wago render it as Markdown; the shorthand
# form (manual-changelog: CHANGELOG.md) defaults to plain text, which CF does
# not display as a formatted changelog.
manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

# Keep development-only files out of the packaged zip.
# (media/ holds the CurseForge listing art and must not ship inside the addon.
#  NOTE: keep these as full-line comments — the packager does NOT strip inline
#  comments from list items and eval's the patterns, so a trailing "# ..." breaks
#  the file copy and produces an empty zip.)
ignore:
  - ".git"
  - ".gitignore"
  - ".github"
  - ".pkgmeta"
  - ".luacheckrc"
  - "AGENTS.md"
  - "CLAUDE.md"
  - "media"
  - "tools"
